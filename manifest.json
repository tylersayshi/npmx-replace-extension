{
  "manifest_version": 3,
  "name": "npmx Redirect",
  "version": "1.0.0",
  "description": "Redirects npmjs.com package pages to npmx.dev for a better browsing experience",
  "permissions": [
    "declarativeNetRequest",
    "storage"
  ],
  "host_permissions": [
    "*://*.npmjs.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "scripts": ["lib/browser-polyfill.min.js", "background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "npmx-redirect@npmx.dev",
      "strict_min_version": "109.0"
    }
  }
}
